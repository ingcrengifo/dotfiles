{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 3,
  "final_space": true,
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "os",
          "style": "powerline",
          "foreground": "#161821",
          "background": "#D0D0D0",
          "powerline_symbol": "\ue0b0",
          "template": " {{ .Icon }} "
        },
        {
          "type": "path",
          "style": "powerline",
          "foreground": "#FFFFFF",
          "background": "#315BCB",
          "powerline_symbol": "\ue0b0",
          "properties": {
            "style": "full",
            "folder_icon": "\uf07b",
            "folder_separator_icon": "/",
            "home_icon": "~"
          },
          "template": " \uf07b  {{ .Path }} "
        },
        {
          "type": "git",
          "style": "powerline",
          "foreground": "#101010",
          "background": "#00C000",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#D7AF00{{ end }}",
            "{{ if gt .Ahead 0 }}#D7AF00{{ end }}",
            "{{ if gt .Behind 0 }}#D7AF00{{ end }}"
          ],
          "powerline_symbol": "\ue0b0",
          "properties": {
            "branch_icon": "\ue0a0 ",
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "template": " {{ .UpstreamIcon }} {{ .HEAD }} "
        }
      ]
    },
    {
      "type": "rprompt",
      "overflow": "hide",
      "segments": [
        {
          "type": "executiontime",
          "style": "plain",
          "foreground": "#808080",
          "properties": {
            "threshold": 3000,
            "style": "roundrock"
          },
          "template": "{{ .FormattedMs }}"
        },
        {
          "type": "status",
          "style": "plain",
          "foreground": "#FF0000",
          "properties": {
            "always_enabled": false
          },
          "template": " x{{ .Code }}"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "foreground": "#00D700",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#FF0000{{ end }}"
          ],
          "template": "\u276f"
        }
      ]
    }
  ]
}
