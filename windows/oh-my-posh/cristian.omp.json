{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 3,
  "final_space": true,
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "os",
          "style": "plain",
          "foreground": "#7AA2F7",
          "template": "{{ .Icon }} "
        },
        {
          "type": "path",
          "style": "plain",
          "foreground": "#C0CAF5",
          "properties": {
            "style": "folder"
          },
          "template": "{{ .Path }} "
        },
        {
          "type": "git",
          "style": "plain",
          "foreground": "#9ECE6A",
          "properties": {
            "branch_icon": "git ",
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "template": "{{ .HEAD }}{{ if .Working.Changed }} *{{ end }}{{ if .Staging.Changed }} +{{ end }} "
        },
        {
          "type": "executiontime",
          "style": "plain",
          "foreground": "#E0AF68",
          "properties": {
            "threshold": 500,
            "style": "roundrock"
          },
          "template": "{{ .FormattedMs }} "
        },
        {
          "type": "status",
          "style": "plain",
          "foreground": "#F7768E",
          "properties": {
            "always_enabled": false
          },
          "template": "x{{ .Code }} "
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "foreground": "#BB9AF7",
          "template": ">"
        }
      ]
    }
  ]
}
